{
  "name": "aura-ml-orchestrator-ts",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript control plane for ML/media features with pluggable Python workers",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "job:train-cf-priors": "tsx src/jobs/trainCollaborativePriors.ts",
    "job:build-scut-calibration": "tsx src/jobs/buildScutCalibration.ts",
    "job:manage-reranker-rollout": "tsx src/jobs/manageRerankerRollout.ts",
    "job:build-nsfw-calibration": "tsx src/jobs/buildNsfwCalibration.ts",
    "job:build-deepfake-calibration": "tsx src/jobs/buildDeepfakeCalibration.ts",
    "job:evaluate-reranker-offline": "tsx src/jobs/evaluateRerankerOffline.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "fastify": "^5.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "vitest": "^3.0.6"
  }
}
