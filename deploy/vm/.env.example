# Domain + TLS
DOMAIN=app.example.com
APPS_BASE_DOMAIN=apps.example.com
LETSENCRYPT_EMAIL=ops@example.com

# Container image
AURA_IMAGE=ghcr.io/tashiscool/alovoa:latest
JAVA_TOOL_OPTIONS=-Xmx768m

# MariaDB
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=alovoa
MYSQL_USER=alovoa
MYSQL_PASSWORD=change-me

# SMTP
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=mailer@example.com
SPRING_MAIL_PASSWORD=change-me
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_STARTTLS=true

# Backblaze B2 / S3-compatible storage
S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
S3_REGION=us-west-004
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_MEDIA=aura-media
B2_BUCKET_VIDEO=aura-video
