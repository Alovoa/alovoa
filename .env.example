# AURA Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Backblaze B2 Storage (Required for media)
# ===========================================
# Get these from: backblaze.com -> B2 Cloud Storage -> App Keys
B2_APPLICATION_KEY_ID=your_application_key_id
B2_APPLICATION_KEY=your_application_key

# Your B2 region (check your bucket URL, e.g., s3.us-west-004.backblazeb2.com)
S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
S3_REGION=us-west-004

# Bucket names (create these in B2 console first)
B2_BUCKET_MEDIA=aura-media
B2_BUCKET_VIDEO=aura-video

# ===========================================
# Database
# ===========================================
MYSQL_ROOT_PASSWORD=change_me_in_production
MYSQL_DATABASE=alovoa
MYSQL_USER=alovoa
MYSQL_PASSWORD=change_me_in_production

# ===========================================
# AI Providers (Optional - for video analysis)
# ===========================================
# OpenAI (for GPT-4 + Whisper transcription)
OPENAI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Google Gemini
GOOGLE_AI_API_KEY=

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ===========================================
# Moderation + Safety Feature Toggles
# ===========================================
# Java app moderation controls
APP_MODERATION_ENABLED=true
APP_MODERATION_IMAGE_ENABLED=true
APP_MODERATION_IMAGE_THRESHOLD=0.6
APP_MODERATION_TEXT_SERVICE_ENABLED=true

# Java backend ML integration clients (optional)
APP_AURA_ML_QDRANT_ENABLED=false
APP_AURA_ML_QDRANT_URL=http://localhost:6333
APP_AURA_ML_UNLEASH_ENABLED=false
APP_AURA_ML_UNLEASH_URL=http://localhost:4242/api
APP_AURA_ML_OPENFGA_ENABLED=false
APP_AURA_ML_OPENFGA_URL=http://localhost:8080
APP_AURA_BACKEND_JAVA_MEDIA_ENABLED=true
APP_AURA_BACKEND_JAVA_AI_ENABLED=true
APP_AURA_JAVA_MEDIA_STORAGE_PATH=/tmp/aura-java-media
APP_AURA_JAVA_MEDIA_OCR_COMMAND=
APP_AURA_JAVA_MEDIA_OCR_TIMEOUT_SEC=20
APP_AURA_ML_QDRANT_ATTRACTIVENESS_HINT_ENABLED=false
APP_AURA_ML_QDRANT_ATTRACTIVENESS_HINT_COLLECTION=attractiveness_hints
APP_AURA_ML_QDRANT_ATTRACTIVENESS_HINT_MAX_DELTA=0.08

# Attractiveness sync policy gates (Java backend)
APP_AURA_ATTRACTIVENESS_USE_UNLEASH_FLAG=false
APP_AURA_ATTRACTIVENESS_UNLEASH_FLAG_NAME=attractiveness_local_enabled
APP_AURA_ATTRACTIVENESS_OPENFGA_ENFORCE=false
APP_AURA_ATTRACTIVENESS_OPENFGA_OBJECT=feature:attractiveness_local
APP_AURA_ATTRACTIVENESS_OPENFGA_RELATION=can_use
APP_AURA_ATTRACTIVENESS_QUALITY_GATE_ENABLED=true
APP_AURA_ATTRACTIVENESS_QUALITY_GATE_MIN_SCORE=0.30
APP_AURA_ATTRACTIVENESS_QUALITY_GATE_MIN_CONFIDENCE=0.20
APP_AURA_ATTRACTIVENESS_QUALITY_BLEND_WEIGHT=0.20

# NSFW ensemble controls
NSFW_ENABLED=true
NSFW_THRESHOLD=0.60
NSFW_BASELINE=0.02
NSFW_USE_OPENNSFW2=false
NSFW_USE_NUDENET=false
NSFW_USE_CLIP_NSFW=false
NSFW_CLIP_CMD=python3 /app/scripts/nsfw_clip_adapter.py --image {image_path}
NSFW_CLIP_TIMEOUT_SEC=12
NSFW_CLIP_WEIGHT=0.35

# Text moderation controls
TEXT_MODERATION_ENABLED=true
TEXT_MODERATION_MODEL=multilingual
TEXT_MODERATION_BLOCK_THRESHOLD=0.72
TEXT_MODERATION_WARN_THRESHOLD=0.52

# Face quality controls
FACE_QUALITY_ENABLED=true
FACE_QUALITY_PROVIDER=faceqan
FACE_QUALITY_MODEL_VERSION=faceqan_v1
FACE_QUALITY_USE_ADAPTER=true
FACE_QUALITY_CMD=python3 /app/scripts/faceqan_adapter.py --image {image_path}
FACE_QUALITY_TIMEOUT_SEC=12
FACE_QUALITY_ADAPTER_WEIGHT=0.65

# Attractiveness scoring controls
ATTRACTIVENESS_ENABLED=true
ATTRACTIVENESS_PROVIDER=insightface
ATTRACTIVENESS_MODEL_VERSION=oss_v2
DEEP3D_ENABLE=false
